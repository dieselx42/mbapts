# Tag automation
ENABLE_PRECONSTRUCTION_TAG=true
PRECONSTRUCTION_TAG_NAME=Preconstruction Active
PRECONSTRUCTION_CLICK_THRESHOLD=3
PRECONSTRUCTION_WINDOW_DAYS=14
