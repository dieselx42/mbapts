PORT=8787
INGEST_TOKEN=replace-with-random-token

# Follow Up Boss API
FUB_API_KEY=replace-with-your-fub-api-key
FUB_BASE_URL=https://api.followupboss.com/v1
FUB_ORIGIN=miamibeachapartments-newsletter
